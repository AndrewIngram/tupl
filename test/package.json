{
  "name": "@tupl/workspace-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vp test run --config vite.config.ts",
    "test:coverage": "vp test run --config vite.config.ts --coverage",
    "test:ci": "vp test run --config vite.config.ts --coverage --reporter=default --reporter=blob --outputFile.blob=.vitest-reports/test-ci.json",
    "test:watch": "vp test --config vite.config.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@tupl/foundation": "workspace:*",
    "@tupl/planner": "workspace:*",
    "@tupl/provider-drizzle": "workspace:*",
    "@tupl/provider-ioredis": "workspace:*",
    "@tupl/provider-kit": "workspace:*",
    "@tupl/provider-kysely": "workspace:*",
    "@tupl/provider-objection": "workspace:*",
    "@tupl/runtime": "workspace:*",
    "@tupl/schema": "workspace:*",
    "@tupl/schema-model": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
