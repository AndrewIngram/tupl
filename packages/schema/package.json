{
  "name": "@tupl/schema",
  "version": "0.7.0",
  "description": "Schema builder APIs for tupl",
  "homepage": "https://github.com/AndrewIngram/tupl/tree/main/packages/schema#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewIngram/tupl.git",
    "directory": "packages/schema"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "prepublishOnly": "pnpm run build",
    "test": "vp test run",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tupl/provider-kit": "workspace:*",
    "@tupl/runtime": "workspace:*",
    "@tupl/schema-model": "workspace:*"
  }
}
