{
  "name": "@tupl/runtime",
  "version": "0.7.0",
  "description": "Query execution, guardrails, and sessions for tupl",
  "homepage": "https://github.com/AndrewIngram/tupl/tree/main/packages/runtime#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewIngram/tupl.git",
    "directory": "packages/runtime"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./executor": "./src/runtime/executor.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --sourcemap --clean --dts --tsconfig tsconfig.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tupl/foundation": "workspace:*",
    "@tupl/planner": "workspace:*",
    "@tupl/provider-kit": "workspace:*",
    "@tupl/schema-model": "workspace:*",
    "better-result": "^2.7.0"
  }
}
