{
  "name": "@tupl/core",
  "version": "0.7.0",
  "description": "Core runtime and schema APIs for tupl",
  "homepage": "https://github.com/AndrewIngram/tupl/tree/main/packages/core#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewIngram/tupl.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema/index.d.mts",
      "import": "./dist/schema/index.mjs",
      "require": "./dist/schema/index.cjs"
    },
    "./planner": {
      "types": "./dist/planner/index.d.mts",
      "import": "./dist/planner/index.mjs",
      "require": "./dist/planner/index.cjs"
    },
    "./provider-shapes": {
      "types": "./dist/provider-shapes/index.d.mts",
      "import": "./dist/provider-shapes/index.mjs",
      "require": "./dist/provider-shapes/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts src/schema/index.ts src/planner/index.ts src/provider-shapes/index.ts --format esm,cjs --sourcemap --clean --dts --unbundle",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-result": "^2.7.0"
  }
}
