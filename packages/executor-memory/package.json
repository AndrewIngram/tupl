{
  "name": "@sqlql/executor-memory",
  "version": "0.1.0",
  "description": "In-memory execution primitives for sqlql",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --sourcemap --clean --no-dts && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sqlql/core": "workspace:*",
    "@sqlql/sql": "workspace:*"
  }
}
