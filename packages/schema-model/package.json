{
  "name": "@tupl/schema-model",
  "version": "0.7.0",
  "description": "Logical schema DSL, normalization, and validation for tupl",
  "homepage": "https://github.com/AndrewIngram/tupl/tree/main/packages/schema-model#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewIngram/tupl.git",
    "directory": "packages/schema-model"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./constraints": "./src/constraints.ts",
    "./ddl": "./src/ddl.ts",
    "./dsl": "./src/dsl.ts",
    "./definition": "./src/definition.ts",
    "./enums": "./src/enums.ts",
    "./mapping": "./src/mapping/index.ts",
    "./normalized": "./src/normalized.ts",
    "./planning": "./src/planning.ts",
    "./table-planning": "./src/table-planning.ts",
    "./normalization": "./src/normalization.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --sourcemap --clean --dts --tsconfig tsconfig.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tupl/foundation": "workspace:*",
    "@tupl/provider-kit": "workspace:*",
    "better-result": "^2.7.0"
  }
}
