{
  "name": "@tupl/provider-objection",
  "version": "0.6.0",
  "description": "Objection/Knex provider adapter for tupl",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --sourcemap --clean --dts --unbundle --tsconfig tsconfig.build.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-result": "^2.7.0",
    "@tupl/core": "workspace:*"
  },
  "peerDependencies": {
    "knex": ">=2"
  }
}
