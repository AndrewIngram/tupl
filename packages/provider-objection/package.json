{
  "name": "@tupl/provider-objection",
  "version": "0.7.0",
  "description": "Objection/Knex provider adapter for tupl",
  "homepage": "https://github.com/AndrewIngram/tupl/tree/main/packages/provider-objection#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewIngram/tupl.git",
    "directory": "packages/provider-objection"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --sourcemap --clean --dts --unbundle --tsconfig tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tupl/core": "workspace:*"
  },
  "devDependencies": {
    "knex": "^3.1.0",
    "objection": "^3.1.5"
  },
  "peerDependencies": {
    "knex": ">=2",
    "objection": ">=3"
  },
  "peerDependenciesMeta": {
    "objection": {
      "optional": true
    }
  }
}
