{
  "name": "@tupl/provider-kysely",
  "version": "0.7.0",
  "description": "Kysely provider adapter for tupl",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --sourcemap --clean --dts --unbundle --tsconfig tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tupl/core": "workspace:*"
  },
  "peerDependencies": {
    "kysely": ">=0.26"
  },
  "devDependencies": {
    "kysely": "^0.28.11"
  }
}
