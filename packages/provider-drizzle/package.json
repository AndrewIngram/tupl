{
  "name": "@tupl/provider-drizzle",
  "version": "0.6.0",
  "description": "Drizzle adapter helpers for tupl",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --tsconfig tsconfig.build.json --format esm,cjs --sourcemap --clean --dts --unbundle",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-result": "^2.7.0",
    "drizzle-orm": "latest",
    "@tupl/core": "workspace:*"
  }
}
