{
  "name": "@tupl/provider-kit",
  "version": "0.7.0",
  "description": "Provider contracts, entity binding, and shape helpers for tupl adapters",
  "homepage": "https://github.com/AndrewIngram/tupl/tree/main/packages/provider-kit#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewIngram/tupl.git",
    "directory": "packages/provider-kit"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./shapes": "./src/provider/shapes/index.ts",
    "./testing": "./src/testing.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --sourcemap --clean --dts --tsconfig tsconfig.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tupl/foundation": "workspace:*",
    "better-result": "^2.7.0"
  }
}
