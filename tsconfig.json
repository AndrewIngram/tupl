{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@tupl/core": ["./packages/core/src/index.ts"],
      "@tupl/core/schema": ["./packages/core/src/schema/index.ts"],
      "@tupl/core/planner": ["./packages/core/src/planner/index.ts"],
      "@tupl/core/provider-shapes": ["./packages/core/src/provider-shapes/index.ts"],
      "@tupl/schema": ["./packages/schema/src/index.ts"],
      "@tupl/provider-drizzle": ["./packages/provider-drizzle/src/index.ts"],
      "@tupl/provider-ioredis": ["./packages/provider-ioredis/src/index.ts"],
      "@tupl/provider-objection": ["./packages/provider-objection/src/index.ts"],
      "@tupl/provider-kysely": ["./packages/provider-kysely/src/index.ts"],
      "@tupl/example-shared": ["./examples/_shared/src/index.ts"]
    }
  },
  "include": ["src", "test", "examples/**/*.ts"]
}
