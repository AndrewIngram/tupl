{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@tupl/core": ["./packages/core/src/index.ts"],
      "@tupl/core/schema": ["./packages/core/src/schema/index.ts"],
      "@tupl/core/provider": ["./packages/core/src/provider/index.ts"],
      "@tupl/core/provider/shapes": ["./packages/core/src/provider/shapes/index.ts"],
      "@tupl/core/provider-shapes": ["./packages/core/src/provider-shapes/index.ts"],
      "@tupl/core/planner": ["./packages/core/src/planner/index.ts"],
      "@tupl/core/model/rel": ["./packages/core/src/model/rel.ts"],
      "@tupl/core/runtime/executor": ["./packages/core/src/runtime/executor.ts"],
      "@tupl/schema": ["./packages/schema/src/index.ts"],
      "@tupl/provider-drizzle": ["./packages/provider-drizzle/src/index.ts"],
      "@tupl/provider-ioredis": ["./packages/provider-ioredis/src/index.ts"],
      "@tupl/provider-objection": ["./packages/provider-objection/src/index.ts"],
      "@tupl/provider-kysely": ["./packages/provider-kysely/src/index.ts"],
      "@tupl-internal/foundation": ["./packages/internal-foundation/src/index.ts"],
      "@tupl-internal/provider": ["./packages/internal-provider/src/index.ts"],
      "@tupl-internal/provider/shapes": ["./packages/internal-provider/src/shapes/index.ts"],
      "@tupl-internal/schema": ["./packages/internal-schema/src/index.ts"],
      "@tupl-internal/planner": ["./packages/internal-planner/src/index.ts"],
      "@tupl-internal/runtime": ["./packages/internal-runtime/src/index.ts"],
      "@tupl-internal/runtime/executor": ["./packages/internal-runtime/src/executor.ts"],
      "@tupl/example-shared": ["./examples/_shared/src/index.ts"]
    }
  },
  "include": ["src", "test", "examples/**/*.ts"]
}
